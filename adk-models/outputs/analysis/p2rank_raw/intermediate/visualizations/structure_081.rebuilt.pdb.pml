select surf_pocket5, protein and id [71,58,62,63,64,683,60,73,78,990,989,987,682,1005,1008] 
set surface_color,  pcol5, surf_pocket5 
set_color pcol6 = [0.702,0.353,0.278]
select surf_pocket6, protein and id [32,33,541,543,545,980,36,38,573,574,575,577,578,34,593,553,560,551,554,555] 
