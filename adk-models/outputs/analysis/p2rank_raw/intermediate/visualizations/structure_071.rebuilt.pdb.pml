select surf_pocket4, protein and id [23,13,408,95,98,10,6,3,533,535,80,94,1042,1043,1063,1060,1061,1045] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.545]
select surf_pocket5, protein and id [95,98,103,100,131,134,135,137,138,401,126,128,13,408,404,406,118] 
set surface_color,  pcol5, surf_pocket5 
