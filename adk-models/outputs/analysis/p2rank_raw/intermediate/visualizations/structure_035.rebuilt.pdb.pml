select surf_pocket4, protein and id [874,875,877,891,892,893,873,27,31,32,28,538,35,888] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.545]
select surf_pocket5, protein and id [329,309,310,311,312,314,315,313,243,173,331,333,328,238,241,223,228,224,225,227] 
set surface_color,  pcol5, surf_pocket5 
set_color pcol6 = [0.702,0.353,0.278]
select surf_pocket6, protein and id [727,728,731,663,618,620,720,763,726,715,626,760,628,653,655] 
