select surf_pocket4, protein and id [660,662,663,729,731,733,648,652,654,655,656,628,653,735,720,727,725,671,672,673,692,693,696,697,698,701,712,716,717,691,640] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.545]
select surf_pocket5, protein and id [222,314,315,328,312,225,313,238,241,242,243,245,239,188,193,333,223,320,172,173,336] 
