select surf_pocket4, protein and id [403,356,357,358,385,383,340,342,503,325,477,478,460,458,429,322,430,323,143,353,337,15,512,401,405,5,7,8,413,432,433,345] 
set surface_color,  pcol4, surf_pocket4 
