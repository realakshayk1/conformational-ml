select surf_pocket3, protein and id [80,23,1045,1059,1060,1061,1063,1042,1043,1058,533,968,523,93,94,95,96,97,98,978,13,406,3,12,525,128,408,137] 
set surface_color,  pcol3, surf_pocket3 
