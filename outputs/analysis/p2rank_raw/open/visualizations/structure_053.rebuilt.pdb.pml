select surf_pocket4, protein and id [317,321,322,325,318,293,168,333,338,170,172,173,431,432,150,153,152,155] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.545]
select surf_pocket5, protein and id [840,837,838,578,545,551,53,49,46,48,555,560,36,37,39,40,834,835,853,854,855] 
set surface_color,  pcol5, surf_pocket5 
