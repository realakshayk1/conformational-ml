select surf_pocket4, protein and id [320,323,325,475,478,479,503,458,338,412,413,505,145,153,428,432,433,431] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.361]
select surf_pocket5, protein and id [28,31,538,527,528,908,20,526,18] 
set surface_color,  pcol5, surf_pocket5 
set_color pcol6 = [0.702,0.533,0.278]
select surf_pocket6, protein and id [728,726,755,620,622,626,627,760,762,763,655,663,653,720] 
set surface_color,  pcol6, surf_pocket6 
   
        
        deselect
        
        orient
        